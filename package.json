{
  "name": "metabase-mcp",
  "version": "0.1.0",
  "description": "MCP server wrapping the Metabase REST API for AI agent access",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "metabase-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "tsx": "^4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8",
    "vitest": "^2"
  }
}
