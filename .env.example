# Metabase MCP Server — Environment Variables
#
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.

# Base URL of your Metabase instance (no trailing slash)
METABASE_URL=http://localhost:3000

# API key created in Metabase Admin > Settings > Authentication > API Keys
# The key's permission group must have the access level required for your use case.
METABASE_API_KEY=your-api-key-here
